STARKBANK_ENVIRONMENT=sandbox
STARKBANK_PROJECT_ID=your-project-id-here
STARKBANK_PRIVATE_KEY_PATH=./private-key.pem

REDIS_URL=redis://localhost:6379/0

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starkbank_challenge
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starkbank_challenge_test

# ENVs para usar postgres e redis rodando em um container Docker separado.
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/starkbank_challenge
# REDIS_URL=redis://host.docker.internal:6379/0

FLASK_ENV=development
FLASK_DEBUG=1
LOG_LEVEL=DEBUG

INVOICE_MIN_COUNT=8
INVOICE_MAX_COUNT=12
INVOICE_MIN_AMOUNT=1000
INVOICE_MAX_AMOUNT=100000

# Crontab schedule for the invoice creation job (default: every 3 hours)
# Format: "minute hour day month day_of_week"
INVOICE_SCHEDULE_CRON=0 */3 * * *
